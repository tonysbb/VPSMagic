# ============================================
# VPS Magic Backup 配置模板
# 推荐优先通过 `bash vpsmagic.sh init` 生成 config.env
# 本模板更适合人工复核、批量下发或手工调整
# ============================================

# ---------- 使用模式示例 ----------
# 1. 仅本地模式（推荐第一次使用）
#    BACKUP_DESTINATION="local"
#    BACKUP_TARGETS=""
#
# 2. 单远端模式（一个远端即可完成备份/恢复）
#    BACKUP_DESTINATION="remote"
#    BACKUP_TARGETS="R2:mybucket/vpsmagic/{hostname}"
#    BACKUP_PRIMARY_TARGET="R2:mybucket/vpsmagic/{hostname}"
#    BACKUP_ASYNC_TARGET=""
#
# 3. 主备远端模式（主目标 + 异步副本）
#    BACKUP_DESTINATION="remote"
#    BACKUP_TARGETS="OOS:bucket/vpsmagic/{hostname},R2:mybucket/vpsmagic/{hostname}"
#    BACKUP_PRIMARY_TARGET="OOS:bucket/vpsmagic/{hostname}"
#    BACKUP_ASYNC_TARGET="R2:mybucket/vpsmagic/{hostname}"
#
# 注意:
# - 远端恢复前，目标机仍需自行准备 `rclone.conf`
# - 若主目标依赖 OCI，还需自行准备 `/root/.oci/config`

# ---------- 远端存储 ----------
# 多目标优先级列表（逗号分隔），每一项都是完整 `rclone remote:path`
# 支持 `{hostname}` 占位符，例如:
#   BACKUP_TARGETS="R2:mybucket/vpsmagic/{hostname}"
#   BACKUP_TARGETS="openlist_webdav:139Cloud/backup/{hostname}"
#   BACKUP_TARGETS="OOS:bucket-name/vpsmagic/{hostname},R2:mybucket/vpsmagic/{hostname}"
BACKUP_TARGETS=""

# 交互模式下默认选中的主备份/恢复目标
# 支持 `{hostname}` 占位符
# 示例:
#   BACKUP_PRIMARY_TARGET="R2:mybucket/vpsmagic/{hostname}"
#   BACKUP_PRIMARY_TARGET="OOS:bucket-name/vpsmagic/{hostname}"
BACKUP_PRIMARY_TARGET=""

# 备份完成后异步再复制一份到该目标
# 支持 `{hostname}` 占位符
# 留空表示不做异步副本
# 示例:
#   BACKUP_ASYNC_TARGET="R2:mybucket/vpsmagic/{hostname}"
BACKUP_ASYNC_TARGET=""

# 备份 / 恢复时是否先交互列出可选远端路径
BACKUP_INTERACTIVE_TARGETS=true

# 兼容旧配置：如果未设置 BACKUP_TARGETS，则仍可使用单一路径
# 示例 (WebDAV/OpenList): RCLONE_REMOTE="openlist_webdav:139Cloud/backup/{hostname}"
# 示例 (Google Drive):    RCLONE_REMOTE="gdrive:VPSBackup/{hostname}"
# 示例 (S3):              RCLONE_REMOTE="s3:mybucket/vpsmagic/{hostname}"
RCLONE_REMOTE=""

# rclone 配置文件路径
# 留空使用默认:
#   /root/.config/rclone/rclone.conf
# RCLONE_CONF=""

# 上传带宽限制 (留空不限制)
# 示例: "10M" 表示限制为 10MB/s
# RCLONE_BW_LIMIT=""
# 建议: Oracle Object Storage 优先作为 rclone remote 直接上传，不建议默认 mount 后再备份

# 恢复失败后是否允许命令参数视同强确认回滚
# 默认 false；建议只在无人值守批处理时通过命令行显式启用
RESTORE_ROLLBACK_ON_FAILURE=false

# 跨机恢复时，如果远端路径使用了 {hostname}，可在目标机显式指定源主机名
# 示例:
#   RESTORE_SOURCE_HOSTNAME="SOURCE_HOSTNAME"
# 常见用法:
#   bash vpsmagic.sh restore --config /opt/vpsmagic/config.env --source-hostname SOURCE_HOST
# RESTORE_SOURCE_HOSTNAME=""

# ---------- 备份存储 ----------
BACKUP_ROOT="/opt/vpsmagic/backups"
BACKUP_KEEP_LOCAL=3       # 本地保留最近 N 份备份
BACKUP_KEEP_REMOTE=30     # 远端保留最近 N 份备份
BACKUP_PREFIX="vpsmagic"  # 备份文件名前缀
BACKUP_DESTINATION="remote"  # 默认备份目标: remote 或 local
# BACKUP_REMOTE_OVERRIDE=""   # 单次执行也可通过 --remote 覆盖

# ---------- 加密 (可选) ----------
# 设置密码后，备份文件将使用 AES-256-CBC 加密
# 恢复时需要提供相同密码
# BACKUP_ENCRYPTION_KEY=""

# ---------- 备份模块开关 ----------
# 设置为 true 启用，false 禁用
ENABLE_DOCKER_COMPOSE=true    # Docker Compose 项目
ENABLE_DOCKER_STANDALONE=true # 独立 Docker 容器
ENABLE_SYSTEMD=true           # Systemd 服务
ENABLE_REVERSE_PROXY=true     # 反向代理 (Nginx/Caddy/Apache)
ENABLE_DATABASE=true          # 数据库 (MySQL/PostgreSQL/SQLite)
ENABLE_SSL_CERTS=true         # SSL 证书 (Let's Encrypt/acme.sh)
ENABLE_CRONTAB=true           # Crontab 定时任务
ENABLE_FIREWALL=true          # 防火墙规则 (UFW/iptables/nftables/firewalld)
ENABLE_USER_HOME=true         # 用户目录 (dotfiles/SSH keys 等)
ENABLE_CUSTOM_PATHS=true      # 自定义路径

# ---------- 模块参数 ----------

# Docker Compose 项目路径
# "auto" = 自动探测常见路径中的 Compose 项目
# 手动指定 = 逗号分隔的绝对路径
# 示例: COMPOSE_PROJECTS="/opt/downloader, /opt/pdfmaker"
COMPOSE_PROJECTS=auto

# Systemd 服务名称
# "auto" = 自动探测 /etc/systemd/system/ 下的自定义服务
# 手动指定 = 逗号分隔的服务名 (不含 .service 后缀)
# 示例: SYSTEMD_SERVICES="downnow-bot, frpc, caddy"
# 注意: Python 服务 (如 downnow-bot) 会自动探测 venv 并导出 pip freeze
SYSTEMD_SERVICES=auto

# 需要备份的用户目录 (逗号分隔)
# 备份内容: .bashrc, .ssh/authorized_keys, .config/rclone 等
BACKUP_USERS="root"

# 自定义备份路径 (逗号分隔)
# 不属于上述模块的其他文件/目录
# 示例:
#   EXTRA_PATHS="/etc/hostname,/etc/hosts"
#   EXTRA_PATHS="/opt/myapp/config,/srv/extra-data"
# EXTRA_PATHS=""

# ---------- 数据库 ----------

# MySQL/MariaDB Docker 容器名 (逗号分隔)
# 留空 = 自动探测运行中的 MySQL/MariaDB 容器
# DB_MYSQL_CONTAINERS=""

# 主机直装 MySQL 凭据 (非 Docker)
# DB_MYSQL_HOST_USER=""
# DB_MYSQL_HOST_PASS=""

# PostgreSQL Docker 容器名 (逗号分隔)
# 留空 = 自动探测
# DB_POSTGRES_CONTAINERS=""

# SQLite 数据库文件路径 (逗号分隔)
# 示例: DB_SQLITE_PATHS="/opt/downloader/telegram_bot/bot.sqlite3"
# DB_SQLITE_PATHS=""

# ---------- Telegram 通知 (可选) ----------
NOTIFY_ENABLED=false
# TG_BOT_TOKEN=""
# TG_CHAT_ID=""
# 获取方式:
#   1. 在 Telegram 中找 @BotFather 创建 Bot，获得 Token
#   2. 在 Telegram 中找 @userinfobot 获取你的 Chat ID

# ---------- 日志 ----------
LOG_FILE="/var/log/vpsmagic.log"
UI_LANG="zh"              # 界面语言: zh 或 en

# ---------- 定时备份 ----------
# cron 表达式 (默认每天凌晨3点)
SCHEDULE_CRON="0 3 * * *"
# 其他示例:
#   "0 */6 * * *"    = 每6小时
#   "0 3 * * 0"      = 每周日凌晨3点
#   "0 3 1,15 * *"   = 每月1号和15号

# ---------- 在线迁移 (可选) ----------
# 使用 vpsmagic migrate 时的默认参数
# MIGRATE_SSH_PORT=22          # 默认 SSH 端口
# MIGRATE_SSH_KEY=""           # 默认 SSH 密钥路径 (留空使用系统默认)
# MIGRATE_BW_LIMIT=""          # 传输带宽限制 (例如: 10m = 10MB/s)

# ---------- Rsync 增量同步提示 ----------
# 安装 rsync 后，迁移会优先使用 rsync 提速；也可手动做预同步
# 示例:
#   rsync -avz /opt/data/ root@standby:/opt/data/
